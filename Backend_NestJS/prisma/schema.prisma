generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  fullName             String
  email                String              @unique
  passwordHash         String
  phone                String?
  role                 Role                @default(OWNER)
  isActive             Boolean             @default(true)
  specialization       String?
  bio                  String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  staffBookings        Booking[]           @relation("StaffBookings")
  ownedSalons          Salon[]
  staffAvailability    StaffAvailability[]
  staffWaitlistEntries WaitlistEntry[]     @relation("StaffWaitlistEntries")
  staffWalkIns         WalkIn[]            @relation("StaffWalkIns")
  posSales             PosSale[]           @relation("StaffPosSales")
}

model Salon {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  owner     User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id                String              @id @default(cuid())
  salonId           String
  name              String
  city              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  bookings          Booking[]
  salon             Salon               @relation(fields: [salonId], references: [id])
  Resource          Resource[]
  staffAvailability StaffAvailability[]
  waitlistEntries   WaitlistEntry[]
  walkIns           WalkIn[]
  posSales          PosSale[]
  inventoryProducts InventoryProduct[]
}

model Lead {
  id           String     @id @default(cuid())
  fullName     String
  businessName String?
  email        String?
  phone        String?
  city         String?
  message      String?
  formType     String
  sourcePage   String
  status       LeadStatus @default(NEW)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Client {
  id                    String                @id @default(cuid())
  fullName              String
  phone                 String?
  email                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?
  city                  String?
  notes                 String?
  loyaltyPoints         Int                   @default(0)
  walletBalance         Float                 @default(0)
  totalVisits           Int                   @default(0)
  totalSpend            Float                 @default(0)
  lastVisitAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bookings              Booking[]
  clientWaitlistEntries WaitlistEntry[]
  walkIns               WalkIn[]
  posSales              PosSale[]
  clientMemberships     ClientMembership[]
  clientPackages        ClientPackage[]
  walletTransactions    WalletTransaction[]
  giftCards             GiftCard[]
  loyaltyRewards        LoyaltyReward[]
  formSubmissions       ClientFormSubmission[]
  clientNotes           ClientNote[]
  payments              Payment[]
  invoices              Invoice[]
  adjustments           Adjustment[]
  refunds               Refund[]
  cancellations         Cancellation[]
  conversations         MessageConversation[]
  tasks                 Task[]
}

model Booking {
  id          String           @id @default(cuid())
  branchId    String
  clientId    String
  staffId     String?
  resourceId  String?
  title       String
  notes       String?
  status      BookingStatus    @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  totalAmount Float            @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  branch      Branch           @relation(fields: [branchId], references: [id])
  client      Client           @relation(fields: [clientId], references: [id])
  staff       User?            @relation("StaffBookings", fields: [staffId], references: [id])
  resource    Resource?        @relation(fields: [resourceId], references: [id])
  services    BookingService[]
  walkIns     WalkIn[]

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([resourceId])
  @@index([startTime])
  @@index([status])
}

model BookingService {
  id          String   @id @default(cuid())
  bookingId   String
  serviceId   String?
  name        String
  durationMin Int
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
}

model StaffAvailability {
  id        String   @id @default(cuid())
  branchId  String
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  staff     User     @relation(fields: [staffId], references: [id])

  @@unique([branchId, staffId, dayOfWeek, startTime, endTime])
  @@index([branchId])
  @@index([staffId])
}

model WaitlistEntry {
  id             String         @id @default(cuid())
  branchId       String
  clientId       String?
  staffId        String?
  requestedDate  DateTime
  preferredStart DateTime?
  preferredEnd   DateTime?
  serviceName    String?
  notes          String?
  status         WaitlistStatus @default(WAITING)
  priority       Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  branch         Branch         @relation(fields: [branchId], references: [id])
  client         Client?        @relation(fields: [clientId], references: [id])
  staff          User?          @relation("StaffWaitlistEntries", fields: [staffId], references: [id])

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([requestedDate])
  @@index([status])
  @@index([priority])
}

model Resource {
  id          String       @id @default(cuid())
  branchId    String
  name        String
  type        ResourceType
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  branch      Branch       @relation(fields: [branchId], references: [id])
  bookings    Booking[]

  @@index([branchId])
  @@index([type])
  @@index([isActive])
}

model WalkIn {
  id                   String       @id @default(cuid())
  branchId             String
  clientId             String?
  staffId              String?
  bookingId            String?
  customerName         String?
  phone                String?
  serviceName          String?
  notes                String?
  status               WalkInStatus @default(WAITING)
  queueNumber          Int
  arrivalTime          DateTime     @default(now())
  estimatedWaitMinutes Int          @default(0)
  calledAt             DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  booking              Booking?     @relation(fields: [bookingId], references: [id])
  branch               Branch       @relation(fields: [branchId], references: [id])
  client               Client?      @relation(fields: [clientId], references: [id])
  staff                User?        @relation("StaffWalkIns", fields: [staffId], references: [id])

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([bookingId])
  @@index([status])
  @@index([arrivalTime])
  @@index([queueNumber])
}

model Notification {
  id        String               @id @default(cuid())
  branchId  String?
  userId    String?
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  title     String
  message   String
  link      String?
  read      Boolean              @default(false)
  archived  Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([branchId])
  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([archived])
  @@index([createdAt])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]

  @@index([isActive])
}

model Service {
  id          String    @id @default(cuid())
  categoryId  String?
  name        String
  description String?
  durationMin Int
  price       Float     @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    ServiceCategory? @relation(fields: [categoryId], references: [id])
  posSaleItems PosSaleItem[]
  bookings     BookingService[]
  packageServices PackageService[]

  @@index([categoryId])
  @@index([isActive])
}

model PosSale {
  id            String          @id @default(cuid())
  branchId      String
  clientId      String?
  staffId       String?
  items         PosSaleItem[]
  inventoryTransactions InventoryTransaction[]
  totalAmount   Float           @default(0)
  paymentMethod String?
  status        String          @default("COMPLETED")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  branch        Branch          @relation(fields: [branchId], references: [id])
  client        Client?         @relation(fields: [clientId], references: [id])
  staff         User?           @relation("StaffPosSales", fields: [staffId], references: [id])

  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([createdAt])
}

model PosSaleItem {
  id        String             @id @default(cuid())
  saleId    String
  serviceId String?
  productId String?
  name      String
  quantity  Int                @default(1)
  unitPrice Float              @default(0)
  totalPrice Float             @default(0)
  sale      PosSale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service   Service?           @relation(fields: [serviceId], references: [id])
  product   InventoryProduct?  @relation(fields: [productId], references: [id], map: "pos_sale_item_product_id")

  @@index([saleId])
  @@index([productId])
}

model InventoryProduct {
  id            String                 @id @default(cuid())
  branchId      String
  name          String
  sku           String?
  description   String?
  category      String?
  quantity      Int                    @default(0)
  unit          String                 @default("piece")
  minStockLevel Int                    @default(5)
  price         Float                  @default(0)
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  branch        Branch                 @relation(fields: [branchId], references: [id])
  transactions  InventoryTransaction[]
  posSaleItems  PosSaleItem[]

  @@index([branchId])
  @@index([sku])
  @@index([isActive])
  @@index([quantity])
}

model InventoryTransaction {
  id        String                   @id @default(cuid())
  productId String
  type      InventoryTransactionType
  quantity  Int
  notes     String?
  posSaleId String?
  createdAt DateTime                 @default(now())
  product   InventoryProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  posSale   PosSale?                 @relation(fields: [posSaleId], references: [id], map: "inventory_transaction_pos_sale_id")

  @@index([productId])
  @@index([posSaleId])
  @@index([createdAt])
}

model BusinessSetting {
  id        String   @id @default(cuid())
  salonId   String?
  businessName String?
  email     String?
  phone     String?
  address   String?
  currency  String   @default("USD")
  timezone  String   @default("UTC")
  notificationPreferences String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketingCampaign {
  id          String   @id @default(cuid())
  branchId    String?
  name        String
  type        String   @default("SMS")
  audienceCount Int    @default(0)
  status      String   @default("DRAFT")
  scheduledAt DateTime?
  sentAt      DateTime?
  content     String?
  sentCount   Int      @default(0)
  deliveredCount Int   @default(0)
  failedCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId])
  @@index([status])
}

model MembershipPlan {
  id          String              @id @default(cuid())
  name        String
  price       Float               @default(0)
  validityDays Int                @default(30)
  benefits    String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  clientMemberships ClientMembership[]
}

model ClientMembership {
  id               String         @id @default(cuid())
  clientId         String
  membershipPlanId String
  startDate        DateTime       @default(now())
  endDate          DateTime
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  client           Client         @relation(fields: [clientId], references: [id])
  membershipPlan   MembershipPlan @relation(fields: [membershipPlanId], references: [id])

  @@index([clientId])
  @@index([membershipPlanId])
  @@index([isActive])
}

model Package {
  id          String           @id @default(cuid())
  name        String
  description String?
  price       Float            @default(0)
  validityDays Int             @default(90)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  services    PackageService[]
  clientPackages ClientPackage[]
}

model PackageService {
  id        String   @id @default(cuid())
  packageId String
  serviceId String
  sessions  Int      @default(1)
  createdAt DateTime @default(now())
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])

  @@unique([packageId, serviceId])
}

model ClientPackage {
  id            String   @id @default(cuid())
  clientId      String
  packageId     String
  startDate     DateTime @default(now())
  endDate       DateTime
  sessionsUsed  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id])
  package       Package  @relation(fields: [packageId], references: [id])

  @@index([clientId])
  @@index([packageId])
  @@index([isActive])
}

model WalletTransaction {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("CREDIT")
  amount    Float    @default(0)
  balanceAfter Float @default(0)
  notes     String?
  reference String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([createdAt])
}

model GiftCard {
  id          String   @id @default(cuid())
  clientId    String?
  code        String   @unique
  initialBalance Float @default(0)
  balance     Float    @default(0)
  status      String   @default("ACTIVE")
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([code])
  @@index([status])
}

model LoyaltyReward {
  id          String   @id @default(cuid())
  clientId    String
  points      Int      @default(0)
  type        String   @default("EARNED")
  description String?
  reference   String?
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([createdAt])
}

model FormTemplate {
  id          String                @id @default(cuid())
  name        String
  description String?
  fields      String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  submissions ClientFormSubmission[]
}

model ClientFormSubmission {
  id            String       @id @default(cuid())
  clientId      String
  formId        String
  answers       String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id])
  form          FormTemplate @relation(fields: [formId], references: [id])

  @@index([clientId])
  @@index([formId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model OnlineProfile {
  id                  String   @id @default(cuid())
  businessName        String?
  description         String?
  photos              String?
  cancellationWindow  Int      @default(24)
  advanceBookingDays  Int      @default(30)
  slotSizeMinutes     Int      @default(30)
  publicServices      Boolean  @default(true)
  publicStaff         Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id          String     @id @default(cuid())
  posSaleId   String?
  bookingId   String?
  clientId    String?
  amount      Float      @default(0)
  currency    String     @default("USD")
  method      String     @default("CASH")
  status      String     @default("PENDING")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  client      Client?    @relation(fields: [clientId], references: [id])

  @@index([posSaleId])
  @@index([bookingId])
  @@index([clientId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String?
  subtotal        Float         @default(0)
  discount        Float         @default(0)
  discountPercent Float         @default(0)
  tax             Float         @default(0)
  taxRate         Float         @default(0)
  total           Float         @default(0)
  status          String        @default("DRAFT")
  notes           String?
  issuedAt        DateTime?
  voidedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client?       @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]
  receipts        Receipt[]

  @@index([clientId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  totalPrice  Float    @default(0)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Receipt {
  id            String   @id @default(cuid())
  invoiceId     String?
  posSaleId     String?
  receiptNumber String   @unique
  amount        Float    @default(0)
  createdAt     DateTime @default(now())
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([posSaleId])
}

model BillingRule {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Discount {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("PERCENTAGE")
  value     Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Tax {
  id        String   @id @default(cuid())
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Adjustment {
  id          String   @id @default(cuid())
  type        String   @default("MANUAL_CREDIT")
  bookingId   String?
  paymentId   String?
  invoiceId   String?
  posSaleId   String?
  clientId    String?
  amount      Float    @default(0)
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())
  client      Client?  @relation(fields: [clientId], references: [id])

  @@index([type])
  @@index([clientId])
  @@index([createdAt])
}

model Refund {
  id        String   @id @default(cuid())
  paymentId String?
  posSaleId String?
  invoiceId String?
  clientId  String?
  amount    Float    @default(0)
  reason    String?
  createdAt DateTime @default(now())
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([paymentId])
  @@index([posSaleId])
  @@index([clientId])
}

model Cancellation {
  id        String   @id @default(cuid())
  bookingId String?
  invoiceId String?
  clientId  String?
  amount    Float    @default(0)
  reason    String?
  createdAt DateTime @default(now())
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([bookingId])
  @@index([clientId])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String?
  body      String
  variables String?
  channel   String   @default("IN_APP")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageConversation {
  id        String   @id @default(cuid())
  subject   String?
  clientId  String?
  channel   String   @default("IN_APP")
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Message {
  id             String             @id @default(cuid())
  conversationId String
  sender         String             @default("STAFF")
  content        String
  channel        String             @default("IN_APP")
  createdAt      DateTime           @default(now())
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AutomationRule {
  id          String              @id @default(cuid())
  name        String
  triggerType String
  actionType  String
  config      String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  eventLogs   AutomationEventLog[]
}

model AutomationEventLog {
  id            String   @id @default(cuid())
  ruleId        String?
  triggerType   String
  actionType    String
  status        String   @default("PENDING")
  details       String?
  createdAt     DateTime @default(now())
  rule          AutomationRule? @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  assignedTo  String?
  clientId    String?
  bookingId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client?  @relation(fields: [clientId], references: [id])

  @@index([assignedTo])
  @@index([clientId])
  @@index([status])
}

model StaffAttendance {
  id         String   @id @default(cuid())
  staffId    String
  date       DateTime @default(now())
  clockIn    DateTime?
  clockOut   DateTime?
  totalMin   Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([staffId])
  @@index([date])
}

model CommissionRule {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("PERCENTAGE")
  value      Float    @default(0)
  serviceId  String?
  staffId    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payments   CommissionPayment[]
}

model CommissionPayment {
  id             String   @id @default(cuid())
  staffId        String
  commissionRuleId String?
  bookingId      String?
  posSaleId      String?
  amount         Float    @default(0)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  rule           CommissionRule? @relation(fields: [commissionRuleId], references: [id])

  @@index([staffId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

model DataExportJob {
  id         String   @id @default(cuid())
  module     String
  status     String   @default("PENDING")
  filePath   String?
  requestedBy String?
  createdAt  DateTime @default(now())
  completedAt DateTime?
}

model Review {
  id        String   @id @default(cuid())
  clientId  String?
  clientName String?
  rating    Int      @default(5)
  source    String   @default("MANUAL")
  comment   String?
  status    String   @default("PUBLISHED")
  externalId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Survey {
  id        String           @id @default(cuid())
  title     String
  questions String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  responses SurveyResponse[]
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  clientId  String?
  answers   String?
  createdAt DateTime @default(now())
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model Feedback {
  id        String   @id @default(cuid())
  clientId  String?
  clientName String?
  rating    Int?
  message   String?
  source    String   @default("IN_APP")
  createdAt DateTime @default(now())
}

model DeliverySetting {
  id        String   @id @default(cuid())
  channel   String   @unique
  provider  String   @default("PLACEHOLDER")
  config    String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryLog {
  id        String   @id @default(cuid())
  channel   String
  recipient String?
  subject   String?
  body      String?
  status    String   @default("SIMULATED")
  response  String?
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
}

